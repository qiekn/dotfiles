[safe]
  directory = /opt/homebrew/Library/Taps/homebrew/homebrew-core
  directory = /opt/homebrew/Library/Taps/homebrew/homebrew-cask
  directory = C:/msys64/home/user/playground/tauri
  directory = C:/msys64/home/user/GameDev/raylib/baba-is-you
[user]
  name = qiekn
  email = qiekndev@gmail.com
[init]
  defaultBranch = main
[core]
  pager = delta
  editor = nvim
  excludesfile = ~/.gitignore_global
  autocrlf = false
  eol = lf
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
  dark = true      # or `light = true`, or omit for auto-detection
[color]
  ui = true
[https]
  #proxy = http://127.0.0.1:7890
[alias]
  co = checkout
  br = branch
  st = stash
  rb = rebase
  cp = cherry-pick
  lg = log --oneline --abbrev --author=qiekn
  browse = "!f() { \n  url=$(git remote get-url origin);\n  url=${url/git@github.com:/https://github.com/};\n  url=${url%.git};\n  start \"$url\"; \n}; f"
  diff-side-by-side = -c delta.features=side-by-side diff
[diff]
  tool = nvimdiff
[filter "lfs"]
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
