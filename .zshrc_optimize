# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt share_history hist_ignore_dups hist_ignore_space hist_reduce_blanks

# --- Completion ---
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # case-insensitive

# --- Colors ---
autoload -U colors && colors

# --- Vi mode ---
bindkey -v
export KEYTIMEOUT=1

# Vi mode cursor: beam for insert, block for normal
zle-keymap-select() {
  if [[ $KEYMAP == vicmd ]]; then
    echo -ne '\e[2 q'  # block
  else
    echo -ne '\e[6 q'  # beam
  fi
}
zle-line-init() { echo -ne '\e[6 q' }
zle -N zle-keymap-select
zle -N zle-line-init

# --- Key bindings ---
bindkey '^[[A' up-line-or-search        # Up
bindkey '^[[B' down-line-or-search      # Down
bindkey '^[[H' beginning-of-line        # Home
bindkey '^[[F' end-of-line              # End
bindkey '^[[3~' delete-char             # Delete

# --- Git prompt (替代 omz git.zsh) ---
git_prompt_info() {
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
  local dirty=""
  if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
    dirty=" ✗"
  fi
  echo "%{$fg_bold[blue]%}git:(%{$fg[red]%}${branch}%{$fg[blue]%})%{$fg[yellow]%}${dirty}%{$reset_color%} "
}

# --- Prompt (robbyrussell 风格) ---
setopt prompt_subst
PROMPT='%(?:%{$fg_bold[green]%}➜ :%{$fg_bold[red]%}➜ ) %{$fg[cyan]%}%c%{$reset_color%} $(git_prompt_info)'

# --- Directory options ---
setopt auto_cd auto_pushd pushd_ignore_dups

# --- Source 自定义配置 ---
export ZSH_CUSTOM="$HOME/.config/zsh"
for f in "$ZSH_CUSTOM"/*.zsh; do
  [[ -f "$f" ]] && source "$f"
done

# --- 环境变量 ---
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR='nvim'
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
export PATH=$PATH:"/c/Program Files/Git/cmd"

# --- Zoxide ---
# cargo install zoxide
# you can type zi to use fzf
eval "$(zoxide init zsh --cmd c)"
