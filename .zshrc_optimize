## History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt share_history hist_ignore_dups hist_ignore_space hist_reduce_blanks

## Completion
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # case-insensitive

## Colors
autoload -U colors && colors

## Vi mode
bindkey -v
export KEYTIMEOUT=15

# beam for insert, block for normal
zle-keymap-select() {
  if [[ $KEYMAP == vicmd ]]; then
    echo -ne '\e[2 q'  # block
  else
    echo -ne '\e[6 q'  # beam
  fi
}
zle-line-init() { echo -ne '\e[6 q' }
zle -N zle-keymap-select
zle -N zle-line-init

## Key bindings
bindkey '^[[A' up-line-or-search        # Up
bindkey '^[[B' down-line-or-search      # Down
bindkey '^[[H' beginning-of-line        # Home
bindkey '^[[F' end-of-line              # End
bindkey '^[[3~' delete-char             # Delete

## Git prompt
git_prompt_info() {
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
  local dirty=""
  if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
    dirty=" ✗"
  fi
  echo "%{$fg_bold[blue]%}git:(%{$fg[red]%}${branch}%{$fg[blue]%})%{$fg[yellow]%}${dirty}%{$reset_color%} "
}

## Prompt (robbyrussell)
setopt prompt_subst
PROMPT='%(?:%{$fg_bold[green]%}➜ :%{$fg_bold[red]%}➜ ) %{$fg[cyan]%}%c%{$reset_color%} $(git_prompt_info)'

## Directory
setopt auto_cd auto_pushd pushd_ignore_dups

## Source custom config
export ZSH_CUSTOM="$HOME/.config/zsh"
source "$ZSH_CUSTOM/loader.zsh"
source "$ZSH_CUSTOM/myshrc.zsh"
